{
  "expo": {
    "name": "stanley-paden",
    "slug": "stanley-paden",
    "notification": {
      "icon": "./assets/icons/notificationsIcon.png",
      "color": "#1A4D7A",
      "androidMode": "default",
      "androidCollapsedTitle": "New notification"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mainLogo.png",
    "scheme": "authorapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/mainLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#132440"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laibaair.stanleypaden"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/mainLogo.png",
        "backgroundColor": "#132440"
      },
      "useNextNotificationsApi": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.laibaair.stanleypaden"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/mainLogo.png" 
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a14cd2e-ec7a-4fde-a2d4-8e490efb513e"
      }
    }
  }
}
