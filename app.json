{
  "expo": {
    "name": "stanley-paden",
    "slug": "stanley-paden",
    "notification": {
      "icon": "./assets/images/icons/notificationsIcon.png",
      "color": "#ffffff",
      "androidMode": "default",
      "androidCollapsedTitle": "New notification"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/brand/icon.png",
    "scheme": "authorapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./public/brand/splashScreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laibaair.stanleypaden"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/brand/adaptive-icon.png",
        "backgroundColor": "#ffffff",
        "googleServicesFile": "@env:GOOGLE_SERVICES_JSON"
      },
      "useNextNotificationsApi": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.laibaair.stanleypaden"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./public/brand/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a14cd2e-ec7a-4fde-a2d4-8e490efb513e"
      }
    }
  }
}
